{
  "name": "rbt-scheduler",
  "version": "1.0.0",
  "description": "RBT Scheduler — C++ Interval Tree with Node.js addon bridge",
  "main": "bridge.js",
  "scripts": {
    "build": "node-gyp configure && node-gyp build",
    "rebuild": "node-gyp configure && node-gyp build",
    "clean": "node-gyp clean",
    "start": "node server.js",
    "restart": "kill $(lsof -t -i:3000) 2>/dev/null; sleep 0.3; node server.js",
    "watch": "node watch.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "node-addon-api": "^8.3.0"
  },
  "devDependencies": {
    "node-gyp": "^10.3.1"
  },
  "gypfile": true
}
